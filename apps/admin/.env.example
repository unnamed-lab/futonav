# Admin panel environment. Copy to `.env.local` and fill in real values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service (secret) key — REQUIRED for privileged writes + Storage uploads on
# Supabase Cloud (self-signed tokens are rejected there). Server-only; never
# expose to the client. Dashboard -> Project Settings -> API keys -> service_role.
# Leave empty ONLY for local/self-hosted dev, where the app falls back to a
# self-signed JWT via JWT_SECRET.
SUPABASE_SERVICE_KEY=

# Public Storage bucket for POI/building images.
SUPABASE_STORAGE_BUCKET=futonavapp

# --- Admin panel login (independent of Supabase) ---
# JWT_SECRET signs the admin session cookie and the dev-mode fallback token.
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@futonav.com
ADMIN_PASSWORD=change-me
