# Mobile app environment. Config is per-mode and auto-loaded by Expo:
#   dev  (expo start)           -> copy to .env.development
#   prod (build / eas / export) -> copy to .env.production
# All EXPO_PUBLIC_* vars are embedded in the JS bundle at build time.

# --- Supabase ---
# PROD (cloud): use your project URL + publishable/anon key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# DEV (local Supabase): a phone cannot reach localhost — use your machine's LAN IP.
#   EXPO_PUBLIC_SUPABASE_URL=http://192.168.x.x:54321
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=<local anon key>
# EXPO_PUBLIC_SUPABASE_KEY is accepted as an alias for the anon key.

# --- Google Maps ---
# Native Maps SDK (Android/iOS) — injected into the manifests at prebuild time.
GOOGLE_MAPS_ANDROID_KEY=AIza...
GOOGLE_MAPS_IOS_KEY=AIza...
# Used by the JS bundle for the Routes API (must have the Routes API enabled).
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza...
